# REST API for catalog & inquiries (PostgreSQL + Prisma). Default matches Vite proxy to port 4000.
# VITE_STORE_API_URL=/api/store

# Admin panel absolute URL used by `/admin` redirects.
# VITE_ADMIN_PANEL_URL=http://admin.localhost:5174

# Digits only, country code included (e.g. India: 919876543210). Used for “WhatsApp enquiry” on idol pages.
# VITE_WHATSAPP_NUMBER=919876543210
