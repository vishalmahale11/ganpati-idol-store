# Copy this file to `.env` and set DATABASE_URL for your PostgreSQL database.
#
# First-time setup (creates `Idol` / `Inquiry` tables — required before the API works):
#   cd src/api && pnpm db:deploy
# Optional sample rows:
#   pnpm db:seed
#
# Alternative for local dev without migration history:
#   pnpm db:push

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ganpati_store?schema=public"

# API port (Vite proxies /api/store -> this server)
PORT=4000
